# ── SQL Server ────────────────────────────────────────────────────────────────
SA_PASSWORD=YourStrong!Passw0rd

# ── JWT Authentication ────────────────────────────────────────────────────────
# Minimalno 32 karaktera, nasumični niz
JWT_KEY=CHANGE_ME_RANDOM_SECRET_MINIMUM_32_CHARACTERS_LONG

# ── AES-256 Encryption (za JMBG, bankovni račun) ─────────────────────────────
# Generisati: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_BASE64_ENCODED_AES256_KEY=

# ── Domen (opciono, za produkciju) ───────────────────────────────────────────
DOMAIN=app.your-company.rs
